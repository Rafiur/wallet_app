# Copy this file to .env and fill in real values before running `docker compose up`.
# .env is read automatically by docker compose from the repo root.

# Postgres password (used by both the db and backend services)
DB_PASSWORD=admin1234

# JWT signing secret - MUST be changed for any non-local deployment
JWT_SECRET=change-me-in-production

# Comma-separated list of origins allowed to call the API.
# Add your deployed frontend's origin here once you have one (e.g. https://wallet.example.com).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
